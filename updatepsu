#!/usr/bin/env bash
#

## ANSI colors (256-color). Empty when stdout is not a TTY.
## Palette is warm and high-contrast: a magenta-to-yellow gradient on the
## banner, bold teal labels as a cool counterpoint, lime green for success,
## orange for prompts, pure red for errors. Secondary text stays in the
## user's default foreground so it remains readable on any theme.
if [ -t 1 ]; then
	C_RESET=$'\033[0m'
	C_BOLD=$'\033[1;38;5;87m'      # bold teal - labels, prompts, values
	C_DIM=                          # intentionally empty - default fg for secondary text
	C_RED=$'\033[1;38;5;196m'      # bold pure red - errors, aborts
	C_GREEN=$'\033[1;38;5;82m'     # bold lime - success
	C_YELLOW=$'\033[1;38;5;214m'   # bold orange - prompts, warnings, cancel
	C_CYAN=$'\033[1;38;5;201m'     # bold magenta - banner accent (kept name for compat)
	## Per-line gradient for the 6-line banner: magenta -> pink -> rose -> orange -> gold -> yellow
	BANNER_GRADIENT=($'\033[1;38;5;201m' $'\033[1;38;5;213m' $'\033[1;38;5;204m' $'\033[1;38;5;208m' $'\033[1;38;5;220m' $'\033[1;38;5;226m')
else
	C_RESET= C_BOLD= C_DIM= C_RED= C_GREEN= C_YELLOW= C_CYAN=
	BANNER_GRADIENT=('' '' '' '' '' '')
fi

## Status helpers: every step prints "Action... " then ok/fail terminates the
## line, and result prints the produced value on the next line in bold so it
## stands out. Keeps tense and shape consistent across every step.
step()    { printf '%s... ' "$*"; }
ok()      { printf '%sDone%s\n' "$C_GREEN" "$C_RESET"; }
fail()    { printf '%sFailed%s\n' "$C_RED" "$C_RESET"; }
result()  { printf '  %s%s%s\n' "$C_BOLD" "$*" "$C_RESET"; }
heading() { printf '\n%s%s%s\n' "$C_BOLD" "$*" "$C_RESET"; }

## Set download and install folders
dlfolder=~/Downloads
infolder=~/PSUnreal

## Welcome banner with per-line warm gradient
printf '\n'
i=0
while IFS= read -r line; do
	printf '%s%s%s\n' "${BANNER_GRADIENT[$i]}" "$line" "$C_RESET"
	((i++))
done <<'EOF'
                 _       _
 _   _ _ __   __| | __ _| |_ ___ _ __  ___ _   _
| | | | '_ \ / _` |/ _` | __/ _ \ '_ \/ __| | | |
| |_| | |_) | (_| | (_| | ||  __/ |_) \__ \ |_| |
 \__,_| .__/ \__,_|\__,_|\__\___| .__/|___/\__,_|
      |_|                       |_|
EOF
printf '\n'
cat <<'EOF'
PlaneShift Unreal updater for Linux.

This will fetch the latest PSUnreal client from planeshift.it, verify it
against the published MD5 checksum, and install it. Your settings live in
$HOME/.config/Epic/PSUnreal and are stored separately, so they are not
touched by an install or a refresh.

EOF
## Let the user accept the defaults (just press Enter) or type a different path.
## Skip prompts when stdin isn't a TTY (e.g. piped/scripted) so non-interactive runs keep working.
if [ -t 0 ]; then
	printf "${C_DIM}Press Enter to accept the default in brackets, or type a different path.${C_RESET}\n"
	printf "${C_BOLD}Download folder${C_RESET} [${C_DIM}%s${C_RESET}]: " "$dlfolder"
	read -e -r input
	[ -n "$input" ] && dlfolder="${input/#\~/$HOME}"
	printf "${C_BOLD}Install folder ${C_RESET} [${C_DIM}%s${C_RESET}]: " "$infolder"
	read -e -r input
	[ -n "$input" ] && infolder="${input/#\~/$HOME}"
else
	printf "${C_BOLD}Download folder:${C_RESET} %s\n${C_BOLD}Install folder: ${C_RESET} %s\n" "$dlfolder" "$infolder"
fi

echo
step "Pulling downloads page"
link=$(lynx -dump -listonly -nonumbers https://www.planeshift.it/Download | grep -oE 'https?://[^[:space:]"]+PSUnreal-Linux[^[:space:]"]+\.tar\.bz2' | head -n1)
ok
result "$link"

step "Parsing expected MD5"
expected_md5=$(lynx -dump https://www.planeshift.it/Download | sed -nE 's/.*PSUnreal Linux Client md5 checksum: ([a-f0-9]{32}).*/\1/p')
if [ -n "$expected_md5" ]; then
	ok
	result "$expected_md5"
else
	fail
fi

step "Resolving filename"
filename=$(echo "$link" | sed 's:.*/::')
fullpath=$dlfolder/$filename
ok
result "$fullpath"

step "Detecting installed version"
latest_version=$(echo "$filename" | sed -nE 's/^PSUnreal-Linux-([0-9.]+)\.tar\.bz2$/\1/p')
config_xml=$infolder/PSUnreal/Config/config.xml
if [ -f "$config_xml" ]; then
	installed_version=$(sed -nE 's/.*<version name="([^"]+)".*/\1/p' "$config_xml")
else
	installed_version=""
fi
ok
printf '  %sLatest:    %s%s%s%s\n' "$C_BOLD" "$C_RESET" "$C_BOLD" "$latest_version" "$C_RESET"
printf '  %sInstalled: %s%s%s%s\n' "$C_BOLD" "$C_RESET" "$C_BOLD" "${installed_version:-(none detected)}" "$C_RESET"

step "Ensuring download folder exists"
mkdir -p "$dlfolder"
ok

if [ -f "$fullpath" ]; then
	step "Using cached archive"
	ok
	result "$fullpath"
else
	heading "Downloading $filename..."
	wget -P "$dlfolder" "$link"
	printf '%sDownload complete.%s\n' "$C_GREEN" "$C_RESET"
fi

step "Verifying MD5"
if [ -z "$expected_md5" ]; then
	fail
	printf '%sCould not parse expected MD5 from downloads page. Aborting.%s\n' "$C_RED" "$C_RESET"
	exit 1
fi
actual_md5=$(md5sum "$fullpath" | awk '{print $1}')
if [ "$actual_md5" != "$expected_md5" ]; then
	fail
	printf '  %sExpected:%s %s\n' "$C_BOLD" "$C_RESET" "$expected_md5"
	printf '  %sActual:  %s %s\n' "$C_BOLD" "$C_RESET" "$actual_md5"
	printf '%sDownloaded file may be corrupted or stale. Delete %s and re-run.%s\n' "$C_RED" "$fullpath" "$C_RESET"
	exit 1
fi
ok
result "$actual_md5"

## Decide whether to install. Fresh installs run silently; otherwise ask, with
## wording that depends on whether this is an update, a same-version refresh,
## or an unknown existing install. Replacing the install folder is non-destructive
## to user settings — those live in $HOME/.config/Epic/PSUnreal, which is never touched.
echo
if [ ! -d "$infolder" ] || [ -z "$(ls -A "$infolder" 2>/dev/null)" ]; then
	printf '%s%s is empty — installing latest (%s).%s\n' "$C_BOLD" "$infolder" "$latest_version" "$C_RESET"
	proceed=y
else
	if [ -n "$latest_version" ] && [ "$latest_version" = "$installed_version" ]; then
		printf '%sAlready on the latest version (%s).%s\n' "$C_YELLOW" "$installed_version" "$C_RESET"
		prompt_text="Refresh anyway (re-extract the package)? [y/N]"
		default=n
	elif [ -n "$installed_version" ] && [ -n "$latest_version" ]; then
		printf '%sUpdate available: %s -> %s%s\n' "$C_YELLOW" "$installed_version" "$latest_version" "$C_RESET"
		prompt_text="Install update? [Y/n]"
		default=y
	else
		printf '%sExisting files found in %s (version unknown). Latest available: %s%s\n' "$C_YELLOW" "$infolder" "$latest_version" "$C_RESET"
		prompt_text="Replace with latest? [y/N]"
		default=n
	fi
	printf 'Your settings in $HOME/.config/Epic/PSUnreal are stored separately and will not be touched.\n'
	printf '%s%s%s ' "$C_BOLD" "$prompt_text" "$C_RESET"
	read -r REPLY
	[ -z "$REPLY" ] && REPLY=$default
	if [[ $REPLY =~ ^[Yy]$ ]]; then
		proceed=y
	else
		proceed=n
	fi
fi

if [ "$proceed" = "y" ]; then
	heading "Installing to $infolder..."
	mkdir -p "$infolder"
	tar --recursive-unlink --strip-components=2 -xjvf "$fullpath" -C "$infolder"
	printf '%sInstall complete.%s\n' "$C_GREEN" "$C_RESET"
else
	printf '\n%sCancelled.%s\n' "$C_YELLOW" "$C_RESET"
fi
